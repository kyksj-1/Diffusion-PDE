# ============================================================================
# PROJECT/black/.gitignore — EntroDiff 主开发版
# ============================================================================

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ----- 虚拟环境 -----
.venv/
venv/
env/
ENV/

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----- Jupyter -----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----- 训练产物（绝对不入库）-----
*.pt
*.pth
*.ckpt
*.safetensors
*.h5
*.hdf5

# ----- 日志 / 实验跟踪 -----
runs/
logs/
wandb/
mlruns/
tensorboard/
*.log

# ----- 数据 -----
data/
datasets/
*.npy
*.npz
*.pkl

# ----- 模型缓存 -----
.cache/
*.bin

# ----- 输出（统一在仓库根的 Output/balck/）-----
outputs/
results/

# ----- 临时调试 -----
scratch/
tmp/
*.tmp
.scratch_*

# ----- 配置覆盖 / 个人秘钥 -----
config/local_*.yaml
config/secret_*.yaml
.env
.env.local
*.key
secrets.json
